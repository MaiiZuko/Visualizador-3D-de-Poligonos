# cubo_materiais.obj
# Cubo com 6 materiais diferentes
# Compatível com o visualizador OBJ/MTL

mtllib objetos.mtl
o CuboColorido

# Vértices
v -1 -1  1
v  1 -1  1
v  1  1  1
v -1  1  1
v -1 -1 -1
v  1 -1 -1
v  1  1 -1
v -1  1 -1

# Coordenadas UV
vt 0 0
vt 1 0
vt 1 1
vt 0 1

# Normais
vn  0  0  1
vn  0  0 -1
vn  0  1  0
vn  0 -1  0
vn  1  0  0
vn -1  0  0

# Frente
usemtl vermelho
f 1/1/1 2/2/1 3/3/1 4/4/1

# Trás
usemtl azul
f 6/1/2 5/2/2 8/3/2 7/4/2

# Topo
usemtl verde
f 4/1/3 3/2/3 7/3/3 8/4/3

# Base
usemtl amarelo
f 5/1/4 6/2/4 2/3/4 1/4/4

# Direita
usemtl roxo
f 2/1/5 6/2/5 7/3/5 3/4/5

# Esquerda
usemtl laranja
f 5/1/6 1/2/6 4/3/6 8/4/6
